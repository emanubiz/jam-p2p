# Signaling server configuration.
#
# Copy this file to `.env` and customize values for your environment.
# All variables are optional; the server falls back to safe dev defaults.

# --- Network ---
# HTTP/WS port the signaling server listens on (default 8080).
PORT=8080

# --- Logging ---
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- DoS protection ---
# Maximum number of peers allowed in a single room.
# When reached, new joins receive `{type:"Error",data:{message:"Room is full"}}`.
MAX_PEERS_PER_ROOM=8

# Maximum number of concurrent rooms the server will track.
# When reached, new rooms receive `{type:"Error",data:{message:"Server room limit reached"}}`.
MAX_ROOMS=500

# WS handshake rate limit per IP (per second). Caps the number of new WebSocket
# connections a single IP can open each second; closes the per-connection
# MESSAGE_RATE_LIMIT amplifier. Set to 0 to disable.
WS_CONNECT_LIMIT_PER_IP=10

# --- CORS ---
# Value of the `Access-Control-Allow-Origin` header for HTTP endpoints.
# Defaults to `*` for local dev. In production set this to the exact origin
# that serves the Tauri app's webview (e.g. `tauri://localhost` or a custom scheme)
# to prevent cross-origin abuse of `/health` and `/ice-servers`.
ALLOWED_ORIGIN=*
